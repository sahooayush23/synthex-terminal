# ────────────────────────────────────────────────────────────────────
# Synthex Terminal — backend environment
# Phase 1 needs NO API keys at all (yfinance is keyless).
# Everything below is free-tier, no credit card required.
# ────────────────────────────────────────────────────────────────────

# Port the API listens on (Render sets $PORT automatically)
PORT=8000

# Comma-separated allowed browser origins (add your deployed frontend URL)
FRONTEND_ORIGIN=http://localhost:5173

# ── Optional keys (all free, no credit card) ───────────────────────
# Set FINNHUB_API_KEY to upgrade single US-equity quotes from delayed Yahoo
# (~15 min) to Finnhub REAL-TIME — the security header / DES badge then shows
# "Real-time" instead of "Delayed ~15m". Everything still works without it.
# Finnhub (real-time US quotes, free) → https://finnhub.io/register
FINNHUB_API_KEY=
# FRED — economic data (ECO/GYLD)     → https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# marketaux — news            → https://www.marketaux.com/
MARKETAUX_API_KEY=
# Google Gemini — AI panel    → https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Groq — AI panel fallback    → https://console.groq.com/keys
GROQ_API_KEY=
